# Claude Code tooling
.claude/

# Dependencies
node_modules/

# Auditor output
audit/

# Build output
dist/
*.zip

# Generated documentation
AUDIT-BRIEFING.md
RELEASING.md

# Auto-updater artifacts (written at runtime)
*.new
apply-update.bat
apply-update.sh

# User data (created at runtime by the server)
data/collections.json
data/decks.json
data/*.bak-v*.json
data/schema.json

# Logs & sync state
*.log
data/*.log
data/sync-progress*.json
data/sync-state.json

# Regenerable sync intermediate (4 MB, rewritten on every sync, excluded
# from releases). The other data/*.json files MUST stay tracked: binary
# users download them from raw.githubusercontent.com at release tags
# (see scripts/release/data-update.js and RELEASING.md).
data/raw-cards.json
data/*.json.tmp
