{
  "name": "rush-app",
  "version": "1.2.2",
  "description": "Yu-Gi-Oh! Rush Duel pack-opening simulator, collection tracker, and deck builder. Unofficial, non-commercial fan project — not affiliated with Konami.",
  "private": true,
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "node --use-system-ca scripts/release/build.js",
    "hash-data": "node scripts/release/hash-data.js",
    "test": "node --test"
  },
  "keywords": [],
  "author": "shaser0",
  "license": "SEE LICENSE IN README.md",
  "type": "commonjs",
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "scripts": [
      "scripts/lib/**/*.js",
      "scripts/sync/**/*.js",
      "scripts/pipeline/**/*.js",
      "scripts/release/update.js",
      "scripts/release/data-update.js"
    ]
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0"
  }
}
